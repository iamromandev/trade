{
  "name": "ui",
  "version": "0.0.1",
  "description": "Trade UI",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web:clean": "cd apps/web && bun run clean",
    "_service:clean": "cd apps/service && bun run clean",
    "clean": "rm -rf node_modules bun.lock && bun run web:clean",
    "web:fmt": "cd apps/web && bun run fmt",
    "_service:fmt": "cd apps/service && bun run fmt",
    "web:fmt.chk": "cd apps/web && bun run fmt.chk",
    "_service:fmt.chk": "cd apps/service && bun run fmt.chk",
    "web:chk": "cd apps/web && bun run chk",
    "_service:chk": "cd apps/service && bun run chk",
    "web:dev": "bun run web:fmt && bun run web:chk && cd apps/web && bun run dev",
    "_service:dev": "bun run service:fmt && bun run service:chk && cd apps/service && bun run dev",
    "web:build": "cd apps/web && bun run build",
    "reinstall": "bun run clean && bun install",
    "web:restart": "bun run reinstall && bun run web:dev",
    "_service:restart": "bun run reinstall && bun run service:dev",
    "web:start": "bun install && bun run web:dev",
    "_service:start": "bun install && bun run service:dev"
  },

  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "latest",
    "prettier-plugin-multiline-arrays": "^4.1.10",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "latest"
  }
}
