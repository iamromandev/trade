{
    "name": "web",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "rm -rf dist && rm -rf node_modules",
        "fmt": "bunx prettier . --write",
        "fmt.chk": "bunx prettier --check .",
        "chk": "bunx tsc --noEmit",
        "dev": "bunx vite --mode ssr",
        "build": "bunx vite build"
    },
    "dependencies": {
        "@qwik.dev/core": "^2.0.0-beta.37",
        "@qwik.dev/router": "^2.0.0-beta.37",
        "@qwik-ui/headless": "^0.7.7",
        "@qwik-ui/utils": "^0.3.3",
        "@qwikest/icons": "^0.0.13",
        "class-variance-authority": "^0.7.1"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@tailwindcss/vite": "^4.3.2",
        "prettier": "^3.9.4",
        "tailwindcss": "^4.3.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.6",
        "vite-tsconfig-paths": "^5.1.4",
        "prettier-plugin-multiline-arrays": "^4.1.10",
        "prettier-plugin-tailwindcss": "^0.7.4",
        "typescript-plugin-css-modules": "^5.2.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    }
